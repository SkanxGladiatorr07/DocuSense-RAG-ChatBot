# ══════════════════════════════════════════════════════════════════════════════
# DocuSense RAG API — Environment Variables
# Copy this file to .env and fill in every value marked [REQUIRED].
# The server will refuse to start if any [REQUIRED] variable is missing or
# malformed, printing a clear error report to help you fix it fast.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
# [REQUIRED] Port the HTTP server listens on. Must be 1–65535.
PORT=5000

# [OPTIONAL] Runtime environment. Allowed: development | test | production
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED] MongoDB connection string.
# Local dev : mongodb://localhost:27017/docusense
# Atlas     : mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/docusense
MONGO_URI=mongodb://localhost:27017/docusense

# ── CORS ──────────────────────────────────────────────────────────────────────
# [OPTIONAL] Comma-separated list of allowed frontend origins.
CORS_ORIGIN=http://localhost:3000

# ── Auth / Security ───────────────────────────────────────────────────────────
# [REQUIRED] Secret key used to sign JWTs. Must be ≥ 32 characters.
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=

# [OPTIONAL] Token expiry in vercel/ms format. Default: 7d
JWT_EXPIRES_IN=7d

# ── OpenAI (Phase 3 — RAG Pipeline) ──────────────────────────────────────────
# [OPTIONAL — required in Phase 3]
# OPENAI_API_KEY=

# ── Vector Store (Phase 3) ────────────────────────────────────────────────────
# [OPTIONAL — required in Phase 3]
# PINECONE_API_KEY=
# PINECONE_INDEX=

# ── Gemini (Phase 3 — Ingestion & Querying) ────────────────────────────────────
# [REQUIRED] Google Gemini API key for embedding generation and chat completions.
GEMINI_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# [OPTIONAL] Authentication endpoints rate limit window (ms). Default: 900000 (15m)
RATE_LIMIT_AUTH_WINDOW_MS=900000
# [OPTIONAL] Authentication endpoints max requests. Default: 20
RATE_LIMIT_AUTH_MAX=20

# [OPTIONAL] Chat endpoints rate limit window (ms). Default: 60000 (1m)
RATE_LIMIT_CHAT_WINDOW_MS=60000
# [OPTIONAL] Chat endpoints max requests. Default: 30
RATE_LIMIT_CHAT_MAX=30

# [OPTIONAL] Document upload endpoints rate limit window (ms). Default: 900000 (15m)
RATE_LIMIT_UPLOAD_WINDOW_MS=900000
# [OPTIONAL] Document upload endpoints max requests. Default: 10
RATE_LIMIT_UPLOAD_MAX=10

