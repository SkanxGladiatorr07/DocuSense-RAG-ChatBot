# ── Server ────────────────────────────────────────────────────────────────────
PORT=
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/docusense
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/docusense
MONGO_URI=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

