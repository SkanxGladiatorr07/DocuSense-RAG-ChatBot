# ── Server ────────────────────────────────────────────────────────────────────
PORT=
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/docusense
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/docusense
MONGO_URI=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# ── OpenAI (Phase 3 — RAG Pipeline) ──────────────────────────────────────────
# OPENAI_API_KEY=

# ── Vector Store (Phase 3) ────────────────────────────────────────────────────
# PINECONE_API_KEY=
# PINECONE_INDEX=

# ── Auth / Security (Phase 4) ─────────────────────────────────────────────────
# JWT_SECRET=
# JWT_EXPIRES_IN=7d
